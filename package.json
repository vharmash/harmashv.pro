{
  "name": "harmashv.pro",
  "version": "1.0.3",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-s lint format type-check build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc  --build --force",
    "lint": "eslint . --fix -c eslint.config.js",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e/*.spec.ts",
    "test:unit": "vitest run tests/unit/**/*.spec.ts"
  },
  "peerDependencyRules": {
    "allowedVersions": {
      "eslint": "9"
    }
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0"
    }
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tailwindcss/postcss": "^4.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "~10.2.1",
    "eslint-plugin-vue": "~10.6.2",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.3",
    "typescript": "~5.9.3",
    "unplugin-inject-preload": "^3.0.0",
    "vite": "^8.0.9",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.7"
  }
}
